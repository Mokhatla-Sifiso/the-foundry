generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  email         String   @unique
  name          String   @default("")
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions          Session[]
  accounts          Account[]
  recruiterProfile  RecruiterProfile?

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

/// Pre-trusted administrators. Source of truth for who is allowed to act as admin.
/// Seeded with mokhatla.mzwakhe@gmail.com. New entries can be added by existing admins.
model AdminWhitelist {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  addedBy    String?
  createdAt  DateTime @default(now())

  @@map("admin_whitelist")
}

/// Recruiter profile created post sign-up. One-to-one with User. Distinct from
/// AdminWhitelist — recruiters never appear in that table.
model RecruiterProfile {
  id         String        @id @default(cuid())
  userId     String        @unique
  company    String
  role       String
  url        String
  decision   ScreenDecision @default(pending)
  reason     String?
  verifiedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profile")
}

enum ScreenDecision {
  pending
  approve
  reject

  @@map("screen_decision")
}
