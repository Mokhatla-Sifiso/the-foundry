NEXT_PUBLIC_SITE_URL="https://mzwakhemokhatla.co.za"

# Google Analytics 4. Leave blank to keep analytics off entirely (no script, no
# cookies, CSP stays locked down). Set to your GA4 Measurement ID to enable it;
# it only loads for visitors who accept the Analytics cookie category.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

BETTER_AUTH_SECRET="replace-with-a-32-byte-base64-secret"
BETTER_AUTH_URL="http://localhost:3000"

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Mzwakhe Mokhatla <hello@mzwakhemokhatla.co.za>"

UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"

# Time-boxed escape from the recruiter work-email check, for walking the journey
# with a personal address. Expires on RECRUITER_BYPASS_UNTIL regardless. Leave
# both blank to keep it off. Never grant admin for this: admin short-circuits the
# CV entitlement and makes every gate untestable.
RECRUITER_BYPASS_EMAILS=""
RECRUITER_BYPASS_UNTIL=""

# Live delivery tracker (#workflow section) — reads this repo's real
# state from the public GitHub API (PRs, last push, deployments).
# Public repos work with NO token; ISR caching keeps it under the
# anonymous rate limit. Set a fine-grained read-only PAT only to lift
# rate limits or point at a private/other repo.
# GITHUB_TOKEN=""
# GITHUB_REPO="Mokhatla-Sifiso/the-foundry"
