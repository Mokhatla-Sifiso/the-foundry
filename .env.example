# --- Site URL (used for canonical URLs, sitemap, robots, OG metadata) ---
# Set this once you've attached a custom domain in Vercel. When unset,
# the app falls back to VERCEL_PROJECT_PRODUCTION_URL on prod and
# http://localhost:3000 in dev — so leaving it blank is safe before launch.
NEXT_PUBLIC_SITE_URL="https://mzwakhe.dev"

# --- Neon Postgres ---
# Pooled connection (use this for app runtime).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct connection (use this for migrations/seed via Prisma CLI).
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- BetterAuth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-32-byte-base64-secret"
# Public URL the auth client points to. In dev, http://localhost:3000 is fine.
BETTER_AUTH_URL="http://localhost:3000"

# --- Resend (transactional email) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender — must match a domain you've added in the Resend dashboard.
RESEND_FROM="Mzwakhe Mokhatla <noreply@mzwakhe.dev>"
